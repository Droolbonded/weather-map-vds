# Weather Map - Production environment template
# ----------------------------------------------
# Bu dosya repo'da bir SABLONDUR. Sunucuda gercek degerleri tutmak icin
# kopyala:
#
#   cp .env.production.example .env.production
#   nano .env.production
#
# Gercek .env.production dosyasi .gitignore tarafindan korunur, repo'ya
# COMMITLENMEZ. Sunucu disinda da paylasmayin.

# API Server
# Nginx, /api isteklerini bu portu dinleyen Node surecine proxy'ler.
PORT=5000

# PostgreSQL baglantisi
# Format: postgresql://kullanici:sifre@host:port/veritabani
# Onerilen: ayni VDS uzerinde lokal PostgreSQL.
DATABASE_URL=postgresql://weather_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/weather_db

# Frontend taban yolu (Vite "base"). Site kokten yayinlanacaksa "/" birak.
BASE_PATH=/

# Node calisma modu
NODE_ENV=production
